# ==============================================================================
# Laravel Production Environment Configuration Template
# ==============================================================================
APP_NAME="DepEd ZC Inventory"
APP_ENV=production
APP_KEY=  # Generate using: docker compose exec app php artisan key:generate
APP_DEBUG=false
APP_URL=http://your-server-ip-or-domain
TRUSTED_PROXIES=*

LOG_CHANNEL=stack
LOG_LEVEL=info

# ==============================================================================
# Database Configuration (Connects to the 'db' service in Docker Compose)
# ==============================================================================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=deped_zc_inventory
DB_USERNAME=amu_admin
DB_PASSWORD=your_secure_database_password
DB_ROOT_PASSWORD=your_secure_root_password

# ==============================================================================
# Cache, Session, & Queue Drivers
# ==============================================================================
# Set drivers to 'redis' to leverage the Redis container for better performance,
# or keep as 'database' for default behavior.
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# ==============================================================================
# Redis Configuration (Connects to the 'redis' service in Docker Compose)
# ==============================================================================
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==============================================================================
# Broadcasting & WebSockets (Laravel Reverb)
# ==============================================================================
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=849204
REVERB_APP_KEY=amukey1234
REVERB_APP_SECRET=amusecret1234
REVERB_HOST=your-server-ip-or-domain
REVERB_PORT=8080
REVERB_SCHEME=http

# Client-facing WebSocket variables for Vite build-time compilation
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ==============================================================================
# External APIs
# ==============================================================================
GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================================================
# Mail Settings
# ==============================================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"
